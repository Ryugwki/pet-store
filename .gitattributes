# Enforce LF line endings across the repo to prevent CRLF churn
* text=auto eol=lf

# Explicit text types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.svg  text eol=lf
*.txt  text eol=lf

# Binary assets — never normalize
*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
